{"root": {"children": [{"type": "html", "version": 1, "html": "<!-- Navigation -->\n  <nav class=\"nav\" id=\"nav\">\n    <div class=\"nav-inner container\">\n      <a href=\"#\" class=\"nav-logo\">\n        <span class=\"nav-logo-icon\">\ud83c\udf4a</span>\n        <span class=\"nav-logo-text\">Mise</span>\n      </a>\n      <div class=\"nav-links\">\n        <a href=\"#features\">Features</a>\n        <a href=\"#pricing\">Pricing</a>\n        <a href=\"#download\" class=\"nav-cta\">Download</a>\n      </div>\n    </div>\n  </nav>\n\n  <!-- Hero -->\n  <section class=\"hero\">\n    <div class=\"container hero-inner\">\n      <span class=\"pill\">Recipe Management, Perfected</span>\n      <h1 class=\"hero-title\">Everything in its place.</h1>\n      <p class=\"hero-subtitle\">The premium recipe manager for iPhone and iPad. Collect, cook, plan, and shop \u2014 all in one beautiful app.</p>\n      <div class=\"hero-ctas\">\n        <a href=\"#download\" class=\"btn btn-primary\">\n          <svg class=\"apple-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z\"/></svg>\n          Download on the App Store\n        </a>\n        <a href=\"#features\" class=\"btn btn-text\">Learn More <span class=\"arrow-down\">\u2193</span></a>\n      </div>\n      <div class=\"hero-device\">\n        <div class=\"phone-frame phone-frame--hero\">\n          <div class=\"phone-screen\">\n            <div class=\"phone-placeholder\">\n              <span class=\"phone-placeholder-icon\">\ud83d\udc68\u200d\ud83c\udf73</span>\n              <span class=\"phone-placeholder-text\">Recipe Collection</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Features -->\n  <section id=\"features\" class=\"features\">\n    <div class=\"container\">\n      <div class=\"section-header anim-fade-up\">\n        <h2 class=\"section-title\">Your kitchen companion</h2>\n        <p class=\"section-subtitle\">From discovering a recipe to putting dinner on the table, Mise handles every step.</p>\n      </div>\n\n      <!-- Feature 1: Import -->\n      <div class=\"feature-row anim-fade-up\">\n        <div class=\"feature-text\">\n          <span class=\"chip\">Import</span>\n          <h3 class=\"feature-title\">Paste a link, get a recipe.</h3>\n          <p class=\"feature-desc\">Drop in a URL from any recipe site \u2014 AllRecipes, Bon Appetit, Food Network, NYT Cooking \u2014 and Mise extracts everything: ingredients, steps, photos, and cook times. Migrating from Paprika? Import your entire archive in one tap.</p>\n          <ul class=\"feature-details\">\n            <li>Supports 1,000+ recipe websites</li>\n            <li>Paprika archive import</li>\n            <li>Smart ingredient parsing</li>\n          </ul>\n        </div>\n        <div class=\"feature-mockup\">\n          <div class=\"phone-frame\">\n            <div class=\"phone-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udcf2</span>\n                <span class=\"phone-placeholder-text\">Import Screen</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Feature 2: Cooking Mode (Dark) -->\n      <div class=\"feature-row feature-row--dark anim-fade-up\">\n        <div class=\"feature-mockup\">\n          <div class=\"phone-frame\">\n            <div class=\"phone-screen phone-screen--dark\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udd25</span>\n                <span class=\"phone-placeholder-text\">Cooking Mode</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"feature-text\">\n          <span class=\"chip chip--light\">Cook</span>\n          <h3 class=\"feature-title\">Hands-free, step by step.</h3>\n          <p class=\"feature-desc\">Cooking Mode transforms recipes into a distraction-free walkthrough. Large text, dark background for kitchen visibility, and built-in timers that keep you on track. Swipe through steps \u2014 no scrolling, no squinting.</p>\n          <ul class=\"feature-details feature-details--light\">\n            <li>Dark UI optimized for kitchens</li>\n            <li>Built-in step timers</li>\n            <li>Swipe between steps</li>\n          </ul>\n        </div>\n      </div>\n\n      <!-- Feature 3: Meal Planning -->\n      <div class=\"feature-row anim-fade-up\">\n        <div class=\"feature-text\">\n          <span class=\"chip\">Plan</span>\n          <h3 class=\"feature-title\">Your week, planned in minutes.</h3>\n          <p class=\"feature-desc\">Drag recipes into a weekly calendar \u2014 breakfast, lunch, dinner, snacks. Need inspiration? AI-powered auto-planning suggests meals based on variety, cook time, and your dietary preferences.</p>\n          <ul class=\"feature-details\">\n            <li>Weekly calendar grid</li>\n            <li>AI-powered meal suggestions (Pro)</li>\n            <li>Drag-and-drop simplicity</li>\n          </ul>\n        </div>\n        <div class=\"feature-mockup\">\n          <div class=\"phone-frame\">\n            <div class=\"phone-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udcc5</span>\n                <span class=\"phone-placeholder-text\">Meal Plan</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Feature 4: Grocery Lists -->\n      <div class=\"feature-row anim-fade-up\">\n        <div class=\"feature-mockup\">\n          <div class=\"phone-frame\">\n            <div class=\"phone-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\uded2</span>\n                <span class=\"phone-placeholder-text\">Grocery List</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"feature-text\">\n          <span class=\"chip\">Shop</span>\n          <h3 class=\"feature-title\">From plan to cart, automatically.</h3>\n          <p class=\"feature-desc\">Generate grocery lists from any recipe or your entire meal plan. Ingredients are consolidated (no duplicate onions!) and categorized by aisle \u2014 produce, dairy, pantry, proteins. Tap to check off as you shop.</p>\n          <ul class=\"feature-details\">\n            <li>Auto-generated from meal plans</li>\n            <li>Smart ingredient consolidation</li>\n            <li>Organized by category</li>\n          </ul>\n        </div>\n      </div>\n\n      <!-- Feature 5: Recipe Collection -->\n      <div class=\"feature-row anim-fade-up\">\n        <div class=\"feature-text\">\n          <span class=\"chip\">Collect</span>\n          <h3 class=\"feature-title\">Your recipes, beautifully organized.</h3>\n          <p class=\"feature-desc\">Every recipe lives in one place \u2014 browsable by category, searchable by ingredient, sortable by rating. Rich detail pages with full-bleed food photos, scaling servings with a tap, and all the metadata that makes a recipe yours.</p>\n          <ul class=\"feature-details\">\n            <li>Categories, tags, and star ratings</li>\n            <li>Full-bleed food photography</li>\n            <li>Instant recipe scaling</li>\n          </ul>\n        </div>\n        <div class=\"feature-mockup\">\n          <div class=\"phone-frame\">\n            <div class=\"phone-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udcd6</span>\n                <span class=\"phone-placeholder-text\">Recipe Detail</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Device Ecosystem -->\n  <section class=\"devices\">\n    <div class=\"container devices-inner\">\n      <div class=\"devices-composition\">\n        <div class=\"device-ipad\">\n          <div class=\"tablet-frame\">\n            <div class=\"tablet-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udcf1</span>\n                <span class=\"phone-placeholder-text\">iPad \u2014 Recipe Grid</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"device-iphone\">\n          <div class=\"phone-frame phone-frame--small\">\n            <div class=\"phone-screen\">\n              <div class=\"phone-placeholder\">\n                <span class=\"phone-placeholder-icon\">\ud83d\udcd6</span>\n                <span class=\"phone-placeholder-text\">iPhone</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <h2 class=\"section-title anim-fade-up\">Designed for iPhone and iPad</h2>\n      <p class=\"section-subtitle anim-fade-up\">Optimized for every screen size, with iCloud sync to keep everything in perfect harmony across your devices.</p>\n    </div>\n  </section>\n\n  <!-- Pricing -->\n  <section id=\"pricing\" class=\"pricing\">\n    <div class=\"container\">\n      <div class=\"section-header anim-fade-up\">\n        <h2 class=\"section-title\">Simple, generous pricing</h2>\n        <p class=\"section-subtitle\">Start free with 30 recipes. Upgrade when you're ready.</p>\n      </div>\n      <div class=\"pricing-grid\">\n        <div class=\"pricing-card anim-fade-up\">\n          <h3 class=\"pricing-name\">Mise Free</h3>\n          <p class=\"pricing-price\">Free forever</p>\n          <ul class=\"pricing-features\">\n            <li>Up to 30 recipes</li>\n            <li>Import from any URL</li>\n            <li>Cooking Mode</li>\n            <li>Grocery lists</li>\n            <li>Full search</li>\n          </ul>\n          <a href=\"#download\" class=\"btn btn-outline\">Download Free</a>\n        </div>\n        <div class=\"pricing-card pricing-card--pro anim-fade-up\">\n          <h3 class=\"pricing-name pricing-name--pro\">Mise Pro</h3>\n          <p class=\"pricing-price\">Try free, then upgrade</p>\n          <ul class=\"pricing-features\">\n            <li>Everything in Free, plus:</li>\n            <li><strong>Unlimited recipes</strong></li>\n            <li><strong>AI meal planning</strong></li>\n            <li><strong>iCloud sync</strong></li>\n            <li><strong>Family sharing</strong></li>\n          </ul>\n          <a href=\"#download\" class=\"btn btn-primary\">Start Pro Trial</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Final CTA -->\n  <section id=\"download\" class=\"final-cta\">\n    <div class=\"container final-cta-inner\">\n      <div class=\"final-cta-icon\">\ud83c\udf4a</div>\n      <h2 class=\"final-cta-title\">Your kitchen, organized.</h2>\n      <p class=\"final-cta-subtitle\">Everything in its place. Download Mise and start cooking with confidence.</p>\n      <a href=\"#\" class=\"btn btn-primary btn-large\">\n        <svg class=\"apple-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z\"/></svg>\n        Download on the App Store\n      </a>\n    </div>\n    <div class=\"final-cta-glow\"></div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"footer\">\n    <div class=\"container footer-inner\">\n      <div class=\"footer-col footer-brand\">\n        <div class=\"footer-logo\">\n          <span class=\"nav-logo-icon\">\ud83c\udf4a</span>\n          <span class=\"footer-logo-text\">Mise</span>\n        </div>\n        <p class=\"footer-tagline\">Everything in its place.</p>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">Product</h4>\n        <a href=\"#features\">Features</a>\n        <a href=\"#pricing\">Pricing</a>\n        <a href=\"#download\">Download</a>\n      </div>\n      <div class=\"footer-col\">\n        <h4 class=\"footer-heading\">Company</h4>\n        <a href=\"#\">Privacy Policy</a>\n        <a href=\"#\">Terms of Service</a>\n        <a href=\"#\">Support</a>\n      </div>\n    </div>\n    <div class=\"container footer-bottom\">\n      <p>&copy; 2026 Mise. Made with love and mise en place.</p>\n    </div>\n  </footer>"}], "direction": null, "format": "", "indent": 0, "type": "root", "version": 1}}